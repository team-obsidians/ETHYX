# ETHYX AI backend environment
# These values are backend-only. Never expose them as NEXT_PUBLIC_* vars.

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Backend-only privileged Postgres connection. Must support server-side
# insert/update/delete on audits, fairness_results, and audit_events.
# Never expose this value to the frontend or NEXT_PUBLIC_* env vars.
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=ethyx-uploads

# Required only if Gemini-backed explanations/summaries are enabled.
GEMINI_API_KEY=your-gemini-api-key

FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
BACKEND_PORT=8000
