# ETHYX AI frontend environment
# Only NEXT_PUBLIC_* values belong here. Never add backend secrets.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Deployed frontend must point this at the deployed FastAPI backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: used for metadata. Set to deployed frontend URL in production.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
