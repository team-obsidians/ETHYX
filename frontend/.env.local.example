# ═══════════════════════════════════════════════════
# ETHYX AI — Frontend Environment Variables
# Copy to .env.local and fill in real values
# ═══════════════════════════════════════════════════

# ─── Supabase ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ─── API ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── App Base URL ───────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ═══════════════════════════════════════════════════
# ⚠️  SECURITY RULES — VIOLATION = IMMEDIATE STOP ⚠️
# ═══════════════════════════════════════════════════
#
# ❌ NEVER put these in frontend .env:
#   - AZURE_STORAGE_CONNECTION_STRING
#   - GEMINI_API_KEY
#   - SUPABASE_JWT_SECRET
#
# These belong in the BACKEND .env ONLY.
# If you see NEXT_PUBLIC_AZURE_* or NEXT_PUBLIC_GEMINI_*
# anywhere in the frontend, that is a critical security bug.
# ═══════════════════════════════════════════════════
